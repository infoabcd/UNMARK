# 必填密鑰
# 本項目適合大量批次。少量圖片的環境準備及模型載入成本難以攤薄，不建議個人少量使用。
# Vast API Key。用來建立、查詢、銷毀 Vast 實例。
VAST_API_KEY=
# Hugging Face Token。用來下載模型。
HF_TOKEN=
# LocalWeb API Key。用來保護本地 API，避免其他程式亂開 Vast 任務。
# 可先在設定頁填備註隨機生成一次，再把生成後的明文貼到這裏長期使用。
# UNMARK_LOCAL_API_KEY=

# 不清楚如何申請密鑰時，先看 Docs/basic_services.md。

# 模型與推理設定
# 模型選擇：9B / 4B / KONTEXT / KWR。
UNMARK_MODEL=9B
# 不填 UNMARK_STEPS 時，會使用 model_presets.json 內該模型的 default_steps。
# steps 越高，推理時間及費用通常越高，但不保證輸出品質一定較好。
# UNMARK_STEPS=8
# 固定推理的隨機種子，讓相同模型、圖片及 steps 可重現同一結果。
UNMARK_SEED=42
# 圖片推理時最長邊上限，單位像素。1024 即超過 1024 的圖會等比縮小再處理。
UNMARK_MAX_SIDE=1024
# 每張網址圖片最多下載多少 MB。超過上限會標記失敗，避免塞滿記憶體或磁碟。
UNMARK_MAX_DOWNLOAD_MB=100
# Prompts 目錄內的提示詞檔名，不包括 .md。預設使用「萬能提示詞」。
UNMARK_PROMPT_PRESET=萬能提示詞

# Vast 臨時 GPU 實例設定
## Vast 搜尋的 GPU 型號
UNMARK_GPU_NAME=H200
## Vast 實例磁碟大小，單位 GB。模型下載、依賴及臨時圖片都會佔用空間。
UNMARK_DISK_GB=80
## Vast 實例標籤，方便你在 Vast 後台認出這台機
UNMARK_INSTANCE_LABEL=unmark-batch
## Vast 啟動時使用的 Docker Image；預設為 PyTorch + CUDA 環境
UNMARK_VAST_IMAGE=pytorch/pytorch:2.5.1-cuda12.4-cudnn9-devel
## 遠端機器內的工作目錄，會放置 worker、manifest、輸出圖片及 log
UNMARK_REMOTE_WORK_DIR=/workspace/unmark

# 輸入與任務目錄 (默認就好)
UNMARK_INPUT_CSV=input.csv
UNMARK_INPUT_IMAGES_DIR=input_images
UNMARK_JOBS_DIR=jobs
UNMARK_LOCALWEB_UPLOADS_DIR=localweb_uploads

# all_to_once_script 目錄 (默認就好)
UNMARK_ALL_TO_ONCE_IMPORT_DIR=all_to_once_script/import
UNMARK_ALL_TO_ONCE_WORK_DIR=all_to_once_script/work
UNMARK_ALL_TO_ONCE_EXPORT_DIR=all_to_once_script/export

# 批次與穩定性 (請斟酌)
## 相片遠端清洗設置
## 每個遠端批次最多處理的圖片數量；已完成圖片仍會逐張下載
UNMARK_BATCH_SIZE=100
## 遠端下載及準備輸入圖片的並行數；GPU 推理固定逐張執行
UNMARK_CONCURRENCY=12
## 本地圖片上傳大小上限，單位 MB。主要保護你不要一次把太大的本地圖片批次塞上去
UNMARK_MAX_EMBED_MB=2000
## 單個批次等待完成的最長時間，單位秒。「7200 是 2 小時」
UNMARK_JOB_TIMEOUT_S=7200
## 等遠端環境安裝和 API 就緒的最長時間，單位秒。「900 是 15 分鐘」
UNMARK_BOOTSTRAP_TIMEOUT_S=900
## 實例最長存活時間，單位秒。即使本地程式斷線，超時後遠端亦會嘗試自行銷毀實例
UNMARK_INSTANCE_TTL_S=10800
## 遠端任務完成後預留給本地下載的時間，單位秒。超時後遠端會嘗試自行銷毀實例
UNMARK_REMOTE_RESULT_GRACE_S=900

# 成本保護 (請保持默認)
# 成功後銷毀 Vast 實例；出錯/逾時後固定先補下載，再銷毀實例。
UNMARK_DESTROY_ON_SUCCESS=true
